{
    "name": "philiprehberger/http-retry-client",
    "description": "HTTP client wrapper with automatic retries, exponential backoff, and jitter",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "http",
        "retry",
        "backoff",
        "jitter",
        "psr-18"
    ],
    "homepage": "https://github.com/philiprehberger/http-retry-client",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "suggest": {
        "psr/http-client": "For PSR-18 HTTP client integration (^1.0)"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\HttpRetry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\HttpRetry\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
