{
    "name": "philiprehberger/http-retry-client",
    "description": "HTTP client wrapper with automatic retries, exponential backoff, and jitter",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "http",
        "retry",
        "backoff",
        "jitter",
        "psr-18"
    ],
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "suggest": {
        "psr/http-client": "For PSR-18 HTTP client integration (^1.0)"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\HttpRetry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\HttpRetry\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
